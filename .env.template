# AI网文创作系统 V3 — API Key配置
# 复制此文件为 .env，填入你的API Key

# Anthropic Claude（必须，用于Planner/Writer/Rewriter）
ANTHROPIC_API_KEY=sk-ant-xxxxx

# DeepSeek（推荐，用于Orchestrator/Outline/Compliance/Checker/Tracker）
# 申请地址：https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxx

# Gemini（可选，备用Writer模型，质量高成本低）
# 申请地址：https://aistudio.google.com
GEMINI_API_KEY=AIzaSy-xxxxx

# Kimi（可选，备用Summarizer模型）
# 申请地址：https://platform.moonshot.cn
KIMI_API_KEY=xxxxx

# Qwen（可选，Checker交叉审核第三模型）
QWEN_API_KEY=xxxxx

# MiniMax（abab6.5s-chat 性价比高，适合 Checker/Tracker）
# 申请地址：https://platform.minimaxi.com
MINIMAX_API_KEY=xxxxx
MINIMAX_GROUP_ID=xxxxx

# 自定义 Provider（兼容 OpenAI Chat Completions 格式）
# 适用于：本地 Ollama、阿里云百炼(Qwen)、字节豆包、智谱GLM、中转代理等
# 示例（阿里云百炼）：
#   CUSTOM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
#   CUSTOM_MODEL_ID=qwen-max
# 示例（本地 Ollama）：
#   CUSTOM_API_BASE=http://localhost:11434/v1
#   CUSTOM_MODEL_ID=llama3
CUSTOM_API_KEY=xxxxx
CUSTOM_API_BASE=https://your-endpoint/v1
CUSTOM_MODEL_ID=your-model-name
